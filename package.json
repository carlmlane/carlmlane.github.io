{
  "name": "carlmlane.github.io",
  "version": "1.0.0",
  "description": "Personal website for Carl M. Lane",
  "repository": "https://github.com/carlmlane/carlmlane.github.io.git",
  "homepage": "https://carlmlane.com",
  "scripts": {
    "generate:service-worker": "tsx scripts/generate-service-worker.ts",
    "prebuild": "pnpm generate:service-worker",
    "dev": "next dev --experimental-https",
    "build": "next build",
    "start": "next start",
    "lint": "biome check",
    "format": "biome format --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "author": "Carl M. Lane",
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "type": "module",
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.1",
    "@next/third-parties": "^16.2.1",
    "framer-motion": "^12.38.0",
    "next": "16.2.1",
    "posthog-js": "^1.363.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "schema-dts": "^1.1.5",
    "sugar-high": "^1.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/mdx": "^2.0.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "babel-plugin-react-compiler": "1.0.0",
    "happy-dom": "^20.8.4",
    "lefthook": "^2.1.4",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
