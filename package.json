{
  "name": "carlmlane.github.io",
  "version": "1.0.0",
  "description": "Personal website for Carl M. Lane",
  "repository": "https://github.com/carlmlane/carlmlane.github.io.git",
  "homepage": "https://carlmlane.com",
  "scripts": {
    "generate:service-worker": "tsx scripts/generate-service-worker.ts",
    "generate:image-manifest": "tsx scripts/optimize-images.ts",
    "prebuild": "pnpm generate:service-worker && pnpm generate:image-manifest",
    "dev": "next dev --experimental-https",
    "build": "next build",
    "start": "next start",
    "lint": "biome check",
    "format": "biome format --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "check-all": "pnpm run \"/^(build|lint|test|typecheck|test:e2e)$/\""
  },
  "author": "Carl M. Lane",
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "type": "module",
  "browserslist": [
    "defaults and fully supports es6-module"
  ],
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.7",
    "@next/third-parties": "^16.2.7",
    "next": "16.2.7",
    "posthog-js": "^1.382.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "rehype-slug": "^6.0.0",
    "schema-dts": "^2.0.0",
    "sugar-high": "^1.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/mdx": "^2.0.14",
    "@types/node": "^22.19.20",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.1.8",
    "babel-plugin-react-compiler": "1.0.0",
    "happy-dom": "^20.10.2",
    "lefthook": "^2.1.9",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
